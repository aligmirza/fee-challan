{
  "name": "fee-challan",
  "version": "1.0.0",
  "description": "Fee Challan Management System",
  "author": "Fee Challan System",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"next dev -p 3099\" \"wait-on http://localhost:3099 && electron .\"",
    "electron:build": "next build && electron-builder --config electron-builder.config.js",
    "electron:build:win": "next build && electron-builder --config electron-builder.config.js --win",
    "electron:build:mac": "next build && electron-builder --config electron-builder.config.js --mac",
    "electron:build:linux": "next build && electron-builder --config electron-builder.config.js --linux"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
